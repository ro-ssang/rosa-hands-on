{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "my-service values",
  "type": "object",
  "additionalProperties": false,
  "required": ["image"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "logLevel": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"]
    }
  }
}
