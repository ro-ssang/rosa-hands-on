{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["replicaCount", "image", "service"],
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "image": {
      "type": "object",
      "required": ["repository", "version"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer" }
      }
    }
  }
}
